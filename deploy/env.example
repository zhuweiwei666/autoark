MONGO_URI=mongodb+srv://user:password@example.mongodb.net/autoark
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ALLOWED_ORIGINS=https://app.autoark.work,https://autoark.work
JSON_BODY_LIMIT=2mb
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=replace-with-a-long-random-password
SUPER_ADMIN_EMAIL=admin@autoark.com
SUPER_ADMIN_SYNC=false

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-password

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://app.autoark.work/api/facebook/oauth/callback
FACEBOOK_BULK_AD_REDIRECT_URI=https://app.autoark.work/api/bulk-ad/auth/callback
FACEBOOK_BUSINESS_LOGIN_CONFIG_ID=
OAUTH_STATE_SECRET=replace-with-a-long-random-oauth-state-secret
OAUTH_STATE_TTL_MS=600000

FEISHU_WEBHOOK_VERIFICATION_TOKEN=
FEISHU_WEBHOOK_SIGNING_SECRET=

LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=autoark-materials
R2_PUBLIC_URL=

TLS_DOMAINS=app.autoark.work api.autoark.work
TLS_CERT_NAME=autoark.work
TLS_EMAIL=
AUTOARK_ENABLE_LETSENCRYPT=true
